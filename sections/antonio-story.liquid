{%- liquid
  assign section_id = 'antonio-story-' | append: section.id
  assign layout_class = 'antonio-story--image-left'
  if section.settings.layout == 'image-right'
    assign layout_class = 'antonio-story--image-right'
  endif
-%}

<style>
  /* =============================================
     ANTONIO'S STORY SECTION — antonio-story.liquid
  ============================================= */

  #{{ section_id }} {
    display: flex;
    flex-direction: column;
    width: 100%;
    background: #F9F5EF;
    overflow: hidden;
  }

  /* Desktop split layout */
  @media screen and (min-width: 750px) {
    #{{ section_id }} {
      flex-direction: row;
      min-height: 580px;
    }

    #{{ section_id }}.antonio-story--image-right {
      flex-direction: row-reverse;
    }
  }

  /* ---- Image Panel ---- */
  .antonio-story__image-panel {
    position: relative;
    width: 100%;
    min-height: 300px;
    overflow: hidden;
    flex-shrink: 0;
  }

  @media screen and (min-width: 750px) {
    .antonio-story__image-panel {
      width: 55%;
      min-height: 100%;
    }
  }

  .antonio-story__image {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
  }

  /* Placeholder when no image */
  .antonio-story__placeholder {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 100%;
    height: 100%;
    min-height: 300px;
    background: #1A1A1A;
  }

  @media screen and (min-width: 750px) {
    .antonio-story__placeholder {
      min-height: 580px;
    }
  }

  .antonio-story__placeholder-icon {
    opacity: 0.25;
    color: #F9F5EF;
  }

  /* Bottom dark gradient overlay on image */
  .antonio-story__image-overlay {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    height: 35%;
    background: linear-gradient(to top, rgba(0,0,0,0.45) 0%, rgba(0,0,0,0) 100%);
    pointer-events: none;
  }

  /* ---- Text Panel ---- */
  .antonio-story__text-panel {
    display: flex;
    flex-direction: column;
    justify-content: center;
    background: #F9F5EF;
    padding: 48px 32px;
    width: 100%;
    flex-shrink: 0;
    will-change: transform, opacity;
  }

  @media screen and (min-width: 750px) {
    .antonio-story__text-panel {
      width: 45%;
      padding: 64px 56px;
    }
  }

  @media screen and (min-width: 1200px) {
    .antonio-story__text-panel {
      padding: 72px 72px;
    }
  }

  /* ---- Eyebrow ---- */
  .antonio-story__eyebrow {
    display: block;
    font-family: 'Bebas Neue', sans-serif;
    font-size: 14px;
    color: #C8291E;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    margin-bottom: 16px;
  }

  /* ---- Headline ---- */
  .antonio-story__headline {
    font-family: 'Playfair Display', serif;
    font-weight: 700;
    font-size: 28px;
    line-height: 1.2;
    color: #1A1A1A;
    margin: 0 0 24px;
  }

  @media screen and (min-width: 750px) {
    .antonio-story__headline {
      font-size: 42px;
    }
  }

  /* ---- Body Copy ---- */
  .antonio-story__body {
    font-size: 15px;
    line-height: 1.75;
    color: #3D3023;
    margin-bottom: 32px;
  }

  .antonio-story__body p {
    margin: 0 0 16px;
  }

  .antonio-story__body p:last-child {
    margin-bottom: 0;
  }

  /* ---- Stat Row ---- */
  .antonio-story__stats {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 8px 0;
    margin-bottom: 36px;
  }

  .antonio-story__stat {
    font-family: 'Bebas Neue', sans-serif;
    font-size: 13px;
    letter-spacing: 0.12em;
    color: #1A1A1A;
    text-transform: uppercase;
    white-space: nowrap;
  }

  .antonio-story__stat-bullet {
    color: #C8291E;
    font-size: 10px;
    margin: 0 10px;
    line-height: 1;
    flex-shrink: 0;
  }

  .antonio-story__stat-bullet:last-child {
    display: none;
  }

  /* ---- CTA Button ---- */
  .antonio-story__cta {
    display: inline-block;
    background: #C8291E;
    color: #FFFFFF;
    font-family: 'Bebas Neue', sans-serif;
    font-size: 16px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    text-decoration: none;
    padding: 14px 36px;
    border: 2px solid #C8291E;
    transition: background 0.25s ease, color 0.25s ease;
    align-self: flex-start;
    cursor: pointer;
  }

  .antonio-story__cta:hover,
  .antonio-story__cta:focus {
    background: transparent;
    color: #C8291E;
    outline: none;
  }
</style>

<section
  id="{{ section_id }}"
  class="antonio-story {{ layout_class }}"
  aria-label="{{ section.settings.heading | default: 'Our Story' | escape }}"
>

  {%- comment -%} IMAGE PANEL {%- endcomment -%}
  <div class="antonio-story__image-panel">
    {%- if section.settings.image != blank -%}
      {{
        section.settings.image
        | image_url: width: 1400
        | image_tag:
          class: 'antonio-story__image',
          widths: '600, 800, 1000, 1200, 1400',
          sizes: '(min-width: 750px) 55vw, 100vw',
          loading: 'lazy',
          alt: section.settings.image.alt | default: section.settings.heading | escape
      }}
    {%- else -%}
      <div class="antonio-story__placeholder" aria-hidden="true">
        <svg
          class="antonio-story__placeholder-icon"
          xmlns="http://www.w3.org/2000/svg"
          width="120"
          height="120"
          viewBox="0 0 24 24"
          fill="currentColor"
        >
          <!-- Pizza slice icon -->
          <path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-1 15l-5-5 1.41-1.41L11 14.17l7.59-7.59L20 8l-9 9z"/>
          <path d="M11 2.07V4.1c-3.94.49-7 3.85-7 7.9 0 .37.04.73.08 1.08L7 12l5 5 5-5-1.5-1.5c.32-.76.5-1.6.5-2.5 0-3.54-2.61-6.47-6-6.93zM12 18c-3.31 0-6-2.69-6-6 0-2.97 2.16-5.43 5-5.91V8l4 4-4 4v-2.08c-1.69-.46-3-1.99-3-3.92 0-2.21 1.79-4 4-4s4 1.79 4 4c0 1.93-1.31 3.46-3 3.92V18z"/>
          <!-- Simpler pizza icon path -->
          <circle cx="12" cy="12" r="10" fill="none" stroke="currentColor" stroke-width="1.5"/>
          <path d="M12 2 L12 12 L20.66 17" stroke="currentColor" stroke-width="1.5" fill="none"/>
          <path d="M12 2 L3.34 17 L20.66 17 Z" stroke="currentColor" stroke-width="1.5" fill="none"/>
          <circle cx="9" cy="10" r="1.2"/>
          <circle cx="14" cy="14" r="1.2"/>
          <circle cx="13" cy="8" r="1"/>
        </svg>
      </div>
    {%- endif -%}
    <div class="antonio-story__image-overlay" aria-hidden="true"></div>
  </div>

  {%- comment -%} TEXT PANEL {%- endcomment -%}
  <div class="antonio-story__text-panel" data-antonio-story-text>

    {%- if section.settings.eyebrow != blank -%}
      <span class="antonio-story__eyebrow">{{ section.settings.eyebrow }}</span>
    {%- endif -%}

    {%- if section.settings.heading != blank -%}
      <h2 class="antonio-story__headline">{{ section.settings.heading }}</h2>
    {%- endif -%}

    {%- if section.settings.body != blank -%}
      <div class="antonio-story__body">{{ section.settings.body }}</div>
    {%- endif -%}

    {%- comment -%} STAT ROW {%- endcomment -%}
    {%- assign stats = '' | split: ',' -%}
    {%- if section.settings.stat1 != blank -%}{%- assign stats = stats | push: section.settings.stat1 -%}{%- endif -%}
    {%- if section.settings.stat2 != blank -%}{%- assign stats = stats | push: section.settings.stat2 -%}{%- endif -%}
    {%- if section.settings.stat3 != blank -%}{%- assign stats = stats | push: section.settings.stat3 -%}{%- endif -%}
    {%- if section.settings.stat4 != blank -%}{%- assign stats = stats | push: section.settings.stat4 -%}{%- endif -%}

    {%- if stats.size > 0 -%}
      <div class="antonio-story__stats" aria-label="Key facts">
        {%- for stat in stats -%}
          <span class="antonio-story__stat">{{ stat }}</span>
          <span class="antonio-story__stat-bullet" aria-hidden="true">&#9670;</span>
        {%- endfor -%}
      </div>
    {%- endif -%}

    {%- if section.settings.cta_text != blank -%}
      <a
        class="antonio-story__cta"
        href="{{ section.settings.cta_url | default: '#' }}"
      >
        {{- section.settings.cta_text -}}
      </a>
    {%- endif -%}

  </div>
</section>

<script>
  (function () {
    'use strict';

    var SECTION_ID = '{{ section_id }}';

    function initStoryAnimation() {
      var section = document.getElementById(SECTION_ID);
      if (!section) return;

      var textPanel = section.querySelector('[data-antonio-story-text]');
      if (!textPanel) return;

      // Check GSAP + ScrollTrigger availability
      if (typeof gsap === 'undefined' || typeof ScrollTrigger === 'undefined') {
        // Graceful fallback: ensure panel is visible
        textPanel.style.opacity = '1';
        textPanel.style.transform = 'none';
        return;
      }

      // Register plugin (safe to call multiple times)
      gsap.registerPlugin(ScrollTrigger);

      // Set initial state
      gsap.set(textPanel, { x: 60, opacity: 0 });

      // Animate on scroll
      gsap.to(textPanel, {
        x: 0,
        opacity: 1,
        duration: 0.8,
        ease: 'power3.out',
        scrollTrigger: {
          trigger: section,
          start: 'top 80%',
          once: true,
          toggleActions: 'play none none none'
        }
      });
    }

    // Run after DOM is ready
    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', initStoryAnimation);
    } else {
      initStoryAnimation();
    }

    // Shopify theme editor: re-run when section is selected or reloaded
    document.addEventListener('shopify:section:load', function (e) {
      if (e.detail && e.detail.sectionId && document.getElementById(SECTION_ID)) {
        initStoryAnimation();
      }
    });
  })();
</script>

{% schema %}
{
  "name": "Antonio's Story",
  "tag": "div",
  "class": "antonio-story-wrapper",
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "settings": [
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "select",
      "id": "layout",
      "label": "Image position",
      "options": [
        { "value": "image-left",  "label": "Image left"  },
        { "value": "image-right", "label": "Image right" }
      ],
      "default": "image-left"
    },
    {
      "type": "header",
      "content": "Image"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Story image"
    },
    {
      "type": "header",
      "content": "Text Content"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow text",
      "default": "OUR STORY"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Headline",
      "default": "Born & Raised in Long Island, New York."
    },
    {
      "type": "richtext",
      "id": "body",
      "label": "Body copy",
      "default": "<p>Antonio's isn't a chain. It's not a concept. It's a kitchen run by real New Yorkers who grew up eating pizza the way it was meant to be — hand-stretched dough, San Marzano tomatoes straight from the can, and whole-milk mozzarella that bubbles and chars in a ripping-hot oven.</p><p>Every pie that comes out of our kitchen is built on over 25 years of doing this the right way. No shortcuts. No frozen dough. No compromises on the ingredients we use or the people we hire.</p><p>Long Island made us, and Long Island is who we cook for. Come hungry.</p>"
    },
    {
      "type": "header",
      "content": "Stats"
    },
    {
      "type": "text",
      "id": "stat1",
      "label": "Stat 1",
      "default": "25+ Years"
    },
    {
      "type": "text",
      "id": "stat2",
      "label": "Stat 2",
      "default": "Real New Yorkers"
    },
    {
      "type": "text",
      "id": "stat3",
      "label": "Stat 3",
      "default": "Top Shelf Ingredients"
    },
    {
      "type": "text",
      "id": "stat4",
      "label": "Stat 4",
      "default": "Long Island Born"
    },
    {
      "type": "header",
      "content": "Call to Action"
    },
    {
      "type": "text",
      "id": "cta_text",
      "label": "Button label",
      "default": "Our Menu"
    },
    {
      "type": "url",
      "id": "cta_url",
      "label": "Button URL"
    }
  ],
  "presets": [
    {
      "name": "Antonio's Story",
      "settings": {
        "layout": "image-left",
        "eyebrow": "OUR STORY",
        "heading": "Born & Raised in Long Island, New York.",
        "stat1": "25+ Years",
        "stat2": "Real New Yorkers",
        "stat3": "Top Shelf Ingredients",
        "stat4": "Long Island Born",
        "cta_text": "Our Menu"
      }
    }
  ]
}
{% endschema %}
