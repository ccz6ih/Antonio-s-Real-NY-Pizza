{%- liquid
  assign section_id = 'antonio-story-' | append: section.id
  assign layout_class = 'antonio-story--image-left'
  if section.settings.layout == 'image-right'
    assign layout_class = 'antonio-story--image-right'
  endif
-%}

<style>
  #{{ section_id }} {
    display: flex; flex-direction: column; width: 100%;
    background: #F9F5EF; overflow: hidden;
  }
  @media screen and (min-width: 750px) {
    #{{ section_id }} { flex-direction: row; min-height: 580px; }
    #{{ section_id }}.antonio-story--image-right { flex-direction: row-reverse; }
  }
  .antonio-story__image-panel {
    position: relative; width: 100%; min-height: 300px;
    overflow: hidden; flex-shrink: 0;
  }
  @media screen and (min-width: 750px) {
    .antonio-story__image-panel { width: 55%; min-height: 100%; }
  }
  .antonio-story__image { display: block; width: 100%; height: 100%; object-fit: cover; object-position: center; }
  .antonio-story__placeholder {
    display: flex; align-items: center; justify-content: center;
    width: 100%; height: 100%; min-height: 300px; background: #1A1A1A;
  }
  @media screen and (min-width: 750px) { .antonio-story__placeholder { min-height: 580px; } }
  .antonio-story__placeholder-icon { opacity: 0.25; color: #F9F5EF; }
  .antonio-story__image-overlay {
    position: absolute; bottom: 0; left: 0; right: 0; height: 35%;
    background: linear-gradient(to top, rgba(0,0,0,0.45) 0%, rgba(0,0,0,0) 100%);
    pointer-events: none;
  }
  .antonio-story__text-panel {
    display: flex; flex-direction: column; justify-content: center;
    background: #F9F5EF; padding: 48px 32px; width: 100%;
    flex-shrink: 0; will-change: transform, opacity;
  }
  @media screen and (min-width: 750px) { .antonio-story__text-panel { width: 45%; padding: 64px 56px; } }
  @media screen and (min-width: 1200px) { .antonio-story__text-panel { padding: 72px 72px; } }
  .antonio-story__eyebrow {
    display: block; font-family: 'Bebas Neue', sans-serif;
    font-size: 14px; color: #C8291E; letter-spacing: 0.2em;
    text-transform: uppercase; margin-bottom: 16px;
  }
  .antonio-story__headline {
    font-family: 'Playfair Display', serif; font-weight: 700;
    font-size: 28px; line-height: 1.2; color: #1A1A1A; margin: 0 0 24px;
  }
  @media screen and (min-width: 750px) { .antonio-story__headline { font-size: 42px; } }
  .antonio-story__body { font-size: 15px; line-height: 1.75; color: #3D3023; margin-bottom: 32px; }
  .antonio-story__body p { margin: 0 0 16px; }
  .antonio-story__body p:last-child { margin-bottom: 0; }
  .antonio-story__stats { display: flex; flex-wrap: wrap; align-items: center; gap: 8px 0; margin-bottom: 36px; }
  .antonio-story__stat {
    font-family: 'Bebas Neue', sans-serif; font-size: 13px;
    letter-spacing: 0.12em; color: #1A1A1A; text-transform: uppercase; white-space: nowrap;
  }
  .antonio-story__stat-bullet { color: #C8291E; font-size: 10px; margin: 0 10px; line-height: 1; flex-shrink: 0; }
  .antonio-story__stat-bullet:last-child { display: none; }
  .antonio-story__cta {
    display: inline-block; background: #C8291E; color: #FFFFFF;
    font-family: 'Bebas Neue', sans-serif; font-size: 16px; letter-spacing: 0.18em;
    text-transform: uppercase; text-decoration: none; padding: 14px 36px;
    border: 2px solid #C8291E; transition: background 0.25s ease, color 0.25s ease; align-self: flex-start;
  }
  .antonio-story__cta:hover, .antonio-story__cta:focus { background: transparent; color: #C8291E; outline: none; }
</style>

<section id="{{ section_id }}" class="antonio-story {{ layout_class }}" aria-label="{{ section.settings.heading | default: 'Our Story' | escape }}">

  <div class="antonio-story__image-panel">
    {%- if section.settings.image != blank -%}
      {{ section.settings.image | image_url: width: 1400 | image_tag: class: 'antonio-story__image', widths: '600, 800, 1000, 1200, 1400', sizes: '(min-width: 750px) 55vw, 100vw', loading: 'lazy', alt: section.settings.image.alt | default: section.settings.heading | escape }}
    {%- else -%}
      <div class="antonio-story__placeholder" aria-hidden="true">
        <svg class="antonio-story__placeholder-icon" xmlns="http://www.w3.org/2000/svg" width="120" height="120" viewBox="0 0 24 24" fill="currentColor">
          <circle cx="12" cy="12" r="10" fill="none" stroke="currentColor" stroke-width="1.5"/>
          <path d="M12 2 L12 12 L20.66 17" stroke="currentColor" stroke-width="1.5" fill="none"/>
          <path d="M12 2 L3.34 17 L20.66 17 Z" stroke="currentColor" stroke-width="1.5" fill="none"/>
          <circle cx="9" cy="10" r="1.2"/><circle cx="14" cy="14" r="1.2"/><circle cx="13" cy="8" r="1"/>
        </svg>
      </div>
    {%- endif -%}
    <div class="antonio-story__image-overlay" aria-hidden="true"></div>
  </div>

  <div class="antonio-story__text-panel" data-antonio-story-text>
    {%- if section.settings.eyebrow != blank -%}<span class="antonio-story__eyebrow">{{ section.settings.eyebrow }}</span>{%- endif -%}
    {%- if section.settings.heading != blank -%}<h2 class="antonio-story__headline">{{ section.settings.heading }}</h2>{%- endif -%}
    {%- if section.settings.body != blank -%}<div class="antonio-story__body">{{ section.settings.body }}</div>{%- endif -%}

    {%- if section.settings.stat1 != blank or section.settings.stat2 != blank or section.settings.stat3 != blank or section.settings.stat4 != blank -%}
      <div class="antonio-story__stats" aria-label="Key facts">
        {%- if section.settings.stat1 != blank -%}<span class="antonio-story__stat">{{ section.settings.stat1 }}</span><span class="antonio-story__stat-bullet" aria-hidden="true">&#9670;</span>{%- endif -%}
        {%- if section.settings.stat2 != blank -%}<span class="antonio-story__stat">{{ section.settings.stat2 }}</span><span class="antonio-story__stat-bullet" aria-hidden="true">&#9670;</span>{%- endif -%}
        {%- if section.settings.stat3 != blank -%}<span class="antonio-story__stat">{{ section.settings.stat3 }}</span><span class="antonio-story__stat-bullet" aria-hidden="true">&#9670;</span>{%- endif -%}
        {%- if section.settings.stat4 != blank -%}<span class="antonio-story__stat">{{ section.settings.stat4 }}</span>{%- endif -%}
      </div>
    {%- endif -%}

    {%- if section.settings.cta_text != blank -%}
      <a class="antonio-story__cta" href="{{ section.settings.cta_url | default: '#' }}">{{- section.settings.cta_text -}}</a>
    {%- endif -%}
  </div>
</section>

<script>
  (function () {
    'use strict';
    var SECTION_ID = '{{ section_id }}';
    function initStoryAnimation() {
      var section = document.getElementById(SECTION_ID);
      if (!section) return;
      var textPanel = section.querySelector('[data-antonio-story-text]');
      if (!textPanel) return;
      if (typeof gsap === 'undefined' || typeof ScrollTrigger === 'undefined') {
        textPanel.style.opacity = '1'; textPanel.style.transform = 'none'; return;
      }
      gsap.registerPlugin(ScrollTrigger);
      gsap.set(textPanel, { x: 60, opacity: 0 });
      gsap.to(textPanel, {
        x: 0, opacity: 1, duration: 0.8, ease: 'power3.out',
        scrollTrigger: { trigger: section, start: 'top 80%', once: true, toggleActions: 'play none none none' }
      });
    }
    if (document.readyState === 'loading') { document.addEventListener('DOMContentLoaded', initStoryAnimation); }
    else { initStoryAnimation(); }
    document.addEventListener('shopify:section:load', function (e) {
      if (e.detail && e.detail.sectionId && document.getElementById(SECTION_ID)) { initStoryAnimation(); }
    });
  })();
</script>

{% schema %}
{
  "name": "Antonio's Story",
  "tag": "div",
  "class": "antonio-story-wrapper",
  "disabled_on": { "groups": ["header", "footer"] },
  "settings": [
    { "type": "header", "content": "Layout" },
    {
      "type": "select", "id": "layout", "label": "Image position",
      "options": [
        { "value": "image-left",  "label": "Image left"  },
        { "value": "image-right", "label": "Image right" }
      ],
      "default": "image-left"
    },
    { "type": "header", "content": "Image" },
    { "type": "image_picker", "id": "image", "label": "Story image" },
    { "type": "header", "content": "Text Content" },
    { "type": "text", "id": "eyebrow", "label": "Eyebrow text", "default": "OUR STORY" },
    {
      "type": "text", "id": "heading", "label": "Headline",
      "default": "Long Island Born. Colorado Made. No Shortcuts."
    },
    {
      "type": "richtext", "id": "body", "label": "Body copy",
      "default": "<p>Antonio grew up on Long Island, where real New York pizza isn't a trend — it's a way of life. After 25+ years of making pizza and training under the influence of legendary pizzaiolo Tony Gemignani — whose team won the Food Network Pizza Champions Challenge in 2006 — Antonio packed that obsession into every recipe and brought it to Colorado. The mission was simple: real NY pizza, no shortcuts, no compromises.</p><p>Every pie starts with long-fermented dough, Stanislaus tomatoes from California, and Bacio premium mozzarella. House-made mozzarella and pasta made from Gragnano Italy flour are crafted fresh daily. Tracey hand-forms every NY bagel from scratch — kettled and baked the way it's supposed to be done. In January 2025, Antonio took his Spicy Calabrian pizza to an international competition in Rimini, Italy, competing against the world's best. The judges have already spoken: Antonio's is the #1 pizza in Colorado and earned the title of 2nd Best Cheese Slice in the World.</p><p>You'll find us in Estes Park and Longmont — two Colorado towns that now know what real New York pizza tastes like. Come find out for yourself.</p>"
    },
    { "type": "header", "content": "Stats" },
    { "type": "text", "id": "stat1", "label": "Stat 1", "default": "25+ Years" },
    { "type": "text", "id": "stat2", "label": "Stat 2", "default": "#1 in Colorado" },
    { "type": "text", "id": "stat3", "label": "Stat 3", "default": "World's Best Cheese Slice" },
    { "type": "text", "id": "stat4", "label": "Stat 4", "default": "2 Colorado Locations" },
    { "type": "header", "content": "Call to Action" },
    { "type": "text", "id": "cta_text", "label": "Button label", "default": "Order Now" },
    { "type": "url",  "id": "cta_url",  "label": "Button URL" }
  ],
  "presets": [
    {
      "name": "Antonio's Story",
      "settings": {
        "layout": "image-left",
        "eyebrow": "OUR STORY",
        "heading": "Long Island Born. Colorado Made. No Shortcuts.",
        "body": "<p>Antonio grew up on Long Island, where real New York pizza isn't a trend — it's a way of life. After 25+ years of making pizza and training under the influence of legendary pizzaiolo Tony Gemignani — whose team won the Food Network Pizza Champions Challenge in 2006 — Antonio packed that obsession into every recipe and brought it to Colorado. The mission was simple: real NY pizza, no shortcuts, no compromises.</p><p>Every pie starts with long-fermented dough, Stanislaus tomatoes from California, and Bacio premium mozzarella. House-made mozzarella and pasta made from Gragnano Italy flour are crafted fresh daily. Tracey hand-forms every NY bagel from scratch — kettled and baked the way it's supposed to be done. In January 2025, Antonio took his Spicy Calabrian pizza to an international competition in Rimini, Italy, competing against the world's best. The judges have already spoken: Antonio's is the #1 pizza in Colorado and earned the title of 2nd Best Cheese Slice in the World.</p><p>You'll find us in Estes Park and Longmont — two Colorado towns that now know what real New York pizza tastes like. Come find out for yourself.</p>",
        "stat1": "25+ Years",
        "stat2": "#1 in Colorado",
        "stat3": "World's Best Cheese Slice",
        "stat4": "2 Colorado Locations",
        "cta_text": "Order Now"
      }
    }
  ]
}
{% endschema %}
