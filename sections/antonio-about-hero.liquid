{%- liquid
  assign section_id  = 'antonio-about-hero-' | append: section.id
  assign headline    = section.settings.headline    | default: "When Taste Matters, Come to Antonio's"
  assign award_text  = section.settings.award_text  | default: "Colorado's #1 Ranked New York Pizzeria — Washington Post, September 2023"
  assign sub         = section.settings.subheadline | default: "Authentic NY Pizza. 2 Colorado Locations. Made by actual New Yorkers since 2014."
  assign cta1_text   = section.settings.cta1_text   | default: "Order Now"
  assign cta1_url    = section.settings.cta1_url    | default: "#"
  assign cta2_text   = section.settings.cta2_text   | default: "Pay Forward Slices"
  assign cta2_url    = section.settings.cta2_url    | default: "#"
  assign bg_image    = section.settings.bg_image
-%}

<section id="{{ section_id }}" class="antonio-about-hero" aria-label="About Antonio's Real NY Pizza">
  {%- if bg_image != blank -%}
    <div class="antonio-about-hero__bg">
      {{ bg_image | image_url: width: 2400 | image_tag: loading: 'eager', fetchpriority: 'high', class: 'antonio-about-hero__bg-img', alt: '' }}
    </div>
  {%- endif -%}
  <div class="antonio-about-hero__overlay" aria-hidden="true"></div>

  <div class="antonio-about-hero__inner">
    {%- if award_text != blank -%}
      <div class="antonio-about-hero__award-badge">
        <svg width="15" height="15" viewBox="0 0 24 24" fill="#F5A623" aria-hidden="true"><path d="M12 2l2.4 7.4H22l-6.2 4.5 2.4 7.4L12 17l-6.2 4.3 2.4-7.4L2 9.4h7.6z"/></svg>
        <span>{{ award_text }}</span>
      </div>
    {%- endif -%}

    <h1 class="antonio-about-hero__headline">{{ headline }}</h1>
    <p class="antonio-about-hero__sub">{{ sub }}</p>

    <div class="antonio-about-hero__ctas">
      {%- if cta1_text != blank -%}
        <a href="{{ cta1_url }}" class="antonio-about-hero__btn antonio-about-hero__btn--primary">{{ cta1_text }}</a>
      {%- endif -%}
      {%- if cta2_text != blank -%}
        <a href="{{ cta2_url }}" class="antonio-about-hero__btn antonio-about-hero__btn--ghost">{{ cta2_text }}</a>
      {%- endif -%}
    </div>
  </div>
</section>

<style>
  #{{ section_id }} {
    position: relative;
    display: flex;
    align-items: center;
    justify-content: center;
    min-height: 72vh;
    background: #1A1A1A;
    overflow: hidden;
    text-align: center;
  }
  #{{ section_id }} .antonio-about-hero__bg {
    position: absolute; inset: 0; z-index: 0;
  }
  #{{ section_id }} .antonio-about-hero__bg-img {
    width: 100%; height: 100%; object-fit: cover; object-position: center;
  }
  #{{ section_id }} .antonio-about-hero__overlay {
    position: absolute; inset: 0; z-index: 1;
    background: linear-gradient(180deg, rgba(26,26,26,0.50) 0%, rgba(26,26,26,0.88) 100%);
  }
  #{{ section_id }} .antonio-about-hero__inner {
    position: relative; z-index: 2;
    max-width: 820px;
    padding: 100px 24px 80px;
    display: flex; flex-direction: column; align-items: center; gap: 28px;
  }
  #{{ section_id }} .antonio-about-hero__award-badge {
    display: inline-flex; align-items: center; gap: 10px;
    background: rgba(200, 41, 30, 0.12);
    border: 1px solid rgba(200, 41, 30, 0.55);
    border-radius: 100px;
    padding: 9px 20px;
    font-family: 'Bebas Neue', sans-serif;
    font-size: 12px; letter-spacing: 0.18em;
    color: #F5A623; text-transform: uppercase;
  }
  #{{ section_id }} .antonio-about-hero__headline {
    font-family: 'Playfair Display', serif;
    font-weight: 900; font-style: italic;
    font-size: clamp(38px, 6.5vw, 76px);
    line-height: 1.08; color: #FFFFFF; margin: 0;
  }
  #{{ section_id }} .antonio-about-hero__sub {
    font-family: 'Bebas Neue', sans-serif;
    font-size: clamp(13px, 1.8vw, 17px);
    letter-spacing: 0.18em; color: rgba(249,245,239,0.85);
    text-transform: uppercase; margin: 0;
  }
  #{{ section_id }} .antonio-about-hero__ctas {
    display: flex; flex-wrap: wrap; gap: 16px; justify-content: center;
    margin-top: 8px;
  }
  #{{ section_id }} .antonio-about-hero__btn {
    font-family: 'Bebas Neue', sans-serif;
    font-size: 16px; letter-spacing: 0.18em;
    text-transform: uppercase; text-decoration: none;
    padding: 15px 42px; border: 2px solid transparent;
    transition: background 0.25s ease, color 0.25s ease, border-color 0.25s ease;
    display: inline-block;
  }
  #{{ section_id }} .antonio-about-hero__btn--primary {
    background: #C8291E; color: #FFFFFF; border-color: #C8291E;
  }
  #{{ section_id }} .antonio-about-hero__btn--primary:hover,
  #{{ section_id }} .antonio-about-hero__btn--primary:focus {
    background: transparent; color: #C8291E; outline: none;
  }
  #{{ section_id }} .antonio-about-hero__btn--ghost {
    background: transparent; color: #FFFFFF; border-color: #FFFFFF;
  }
  #{{ section_id }} .antonio-about-hero__btn--ghost:hover,
  #{{ section_id }} .antonio-about-hero__btn--ghost:focus {
    background: #FFFFFF; color: #1A1A1A; outline: none;
  }
</style>

{% schema %}
{
  "name": "About: Hero",
  "tag": "div",
  "class": "antonio-about-hero-wrapper",
  "disabled_on": { "groups": ["header", "footer"] },
  "settings": [
    { "type": "image_picker", "id": "bg_image",    "label": "Background image" },
    { "type": "text",         "id": "award_text",  "label": "Award badge text", "default": "Colorado's #1 Ranked New York Pizzeria — Washington Post, September 2023" },
    { "type": "text",         "id": "headline",    "label": "Headline",         "default": "When Taste Matters, Come to Antonio's" },
    { "type": "text",         "id": "subheadline", "label": "Subheadline",      "default": "Authentic NY Pizza. 2 Colorado Locations. Made by actual New Yorkers since 2014." },
    { "type": "header",       "content": "Primary Button" },
    { "type": "text",         "id": "cta1_text",   "label": "Label",            "default": "Order Now" },
    { "type": "url",          "id": "cta1_url",    "label": "URL" },
    { "type": "header",       "content": "Secondary Button" },
    { "type": "text",         "id": "cta2_text",   "label": "Label",            "default": "Pay Forward Slices" },
    { "type": "url",          "id": "cta2_url",    "label": "URL" }
  ],
  "presets": [
    {
      "name": "About: Hero",
      "settings": {
        "award_text":  "Colorado's #1 Ranked New York Pizzeria — Washington Post, September 2023",
        "headline":    "When Taste Matters, Come to Antonio's",
        "subheadline": "Authentic NY Pizza. 2 Colorado Locations. Made by actual New Yorkers since 2014.",
        "cta1_text":   "Order Now",
        "cta2_text":   "Pay Forward Slices"
      }
    }
  ]
}
{% endschema %}
