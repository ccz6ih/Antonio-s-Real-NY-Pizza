{%- liquid
  assign categories = 'Pizzas,Calzones,Desserts,Wings,Pasta,Salads,Sides,Bagels,Heros' | split: ','
  assign handles = section.settings.handle_pizzas | append: ',' | append: section.settings.handle_calzones | append: ',' | append: section.settings.handle_desserts | append: ',' | append: section.settings.handle_wings | append: ',' | append: section.settings.handle_pasta | append: ',' | append: section.settings.handle_salads | append: ',' | append: section.settings.handle_sides | append: ',' | append: section.settings.handle_bagels | append: ',' | append: section.settings.handle_heros
  assign handles_arr = handles | split: ','
-%}

<style>
  #antonio-menu-nav {
    background-color: #F9F5EF;
    border-bottom: 1px solid rgba(26,26,26,0.10);
    position: relative;
    z-index: 100;
    width: 100%;
    transition: box-shadow 0.25s ease;
  }
  #antonio-menu-nav.is-sticky {
    position: sticky;
    top: 0;
    box-shadow: 0 2px 12px rgba(26,26,26,0.13);
  }
  #antonio-menu-nav-sentinel {
    height: 1px;
    margin-bottom: -1px;
    pointer-events: none;
  }
  .antonio-menu-nav__track {
    display: flex;
    flex-direction: row;
    align-items: center;
    gap: 8px;
    padding: 10px 16px;
    overflow-x: auto;
    -webkit-overflow-scrolling: touch;
    scroll-snap-type: x proximity;
    scrollbar-width: none;
    -ms-overflow-style: none;
  }
  .antonio-menu-nav__track::-webkit-scrollbar { display: none; }
  .antonio-menu-nav__pill {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    white-space: nowrap;
    scroll-snap-align: start;
    flex-shrink: 0;
    padding: 8px 18px;
    border-radius: 999px;
    border: 1.5px solid rgba(26,26,26,0.18);
    font-family: inherit;
    font-size: 0.875rem;
    font-weight: 600;
    letter-spacing: 0.01em;
    text-decoration: none;
    cursor: pointer;
    background-color: #F9F5EF;
    color: #1A1A1A;
    transition: background-color 0.18s ease, color 0.18s ease, border-color 0.18s ease, box-shadow 0.18s ease;
    -webkit-tap-highlight-color: transparent;
    outline-offset: 3px;
  }
  .antonio-menu-nav__pill:hover {
    border-color: #C8291E;
    color: #C8291E;
  }
  .antonio-menu-nav__pill.is-active,
  .antonio-menu-nav__pill[aria-current="page"] {
    background-color: #C8291E;
    color: #FFFFFF;
    border-color: #C8291E;
    box-shadow: 0 2px 8px rgba(200,41,30,0.28);
  }
  @media (min-width: 768px) {
    .antonio-menu-nav__track {
      padding: 12px 24px;
      gap: 10px;
      justify-content: center;
      flex-wrap: wrap;
      overflow-x: visible;
    }
    .antonio-menu-nav__pill { font-size: 0.9rem; }
  }
  @media (min-width: 1200px) {
    .antonio-menu-nav__track { padding: 14px 40px; gap: 12px; }
  }
</style>

<div id="antonio-menu-nav-sentinel" aria-hidden="true"></div>

<nav id="antonio-menu-nav" aria-label="Menu categories" data-section-id="{{ section.id }}">
  <div class="antonio-menu-nav__track" role="list">
    {%- for category in categories -%}
      {%- assign idx = forloop.index0 -%}
      {%- assign raw_handle = handles_arr[idx] | strip -%}
      {%- assign col_handle = raw_handle | default: category | handleize -%}
      {%- assign col_url = '/collections/' | append: col_handle -%}
      {%- assign is_active = false -%}
      {%- if request.path contains col_url -%}{%- assign is_active = true -%}{%- endif -%}
      <a
        href="{{ col_url }}"
        class="antonio-menu-nav__pill{% if is_active %} is-active{% endif %}"
        role="listitem"
        data-handle="{{ col_handle }}"
        data-section-target="#section-{{ col_handle }}"
        {% if is_active %}aria-current="page"{% endif %}
      >{{- category -}}</a>
    {%- endfor -%}
  </div>
</nav>

<script>
(function () {
  'use strict';
  var nav      = document.getElementById('antonio-menu-nav');
  var sentinel = document.getElementById('antonio-menu-nav-sentinel');
  var pills    = Array.from(nav.querySelectorAll('.antonio-menu-nav__pill'));
  var track    = nav.querySelector('.antonio-menu-nav__track');
  if (!nav || !pills.length) return;

  if (sentinel && 'IntersectionObserver' in window) {
    new IntersectionObserver(function (entries) {
      entries.forEach(function (e) {
        nav.classList.toggle('is-sticky', !e.isIntersecting);
      });
    }, { threshold: 0 }).observe(sentinel);
  }

  function setActive(pill) {
    pills.forEach(function (p) { p.classList.remove('is-active'); p.removeAttribute('aria-current'); });
    if (!pill) return;
    pill.classList.add('is-active');
    pill.setAttribute('aria-current', 'page');
    var tr = track.getBoundingClientRect(), pr = pill.getBoundingClientRect();
    track.scrollTo({ left: (pr.left - tr.left + track.scrollLeft) - (tr.width / 2) + (pr.width / 2), behavior: 'smooth' });
  }

  var path = window.location.pathname;
  pills.forEach(function (p) {
    if (path.indexOf('/collections/' + p.dataset.handle) !== -1) setActive(p);
  });

  pills.forEach(function (pill) {
    pill.addEventListener('click', function (e) {
      var el = pill.dataset.sectionTarget ? document.querySelector(pill.dataset.sectionTarget) : null;
      if (el) {
        e.preventDefault();
        setActive(pill);
        window.scrollTo({ top: el.getBoundingClientRect().top + window.pageYOffset - nav.offsetHeight - 8, behavior: 'smooth' });
      } else {
        setActive(pill);
      }
    });
  });

  function initGSAP() {
    if (typeof gsap === 'undefined') return;
    pills.forEach(function (pill) {
      pill.addEventListener('mouseenter', function () {
        if (!pill.classList.contains('is-active')) gsap.to(pill, { scale: 1.05, duration: 0.18, ease: 'power1.out', overwrite: 'auto' });
      });
      pill.addEventListener('mouseleave', function () {
        gsap.to(pill, { scale: 1, duration: 0.18, ease: 'power1.inOut', overwrite: 'auto' });
      });
    });
  }

  if (document.readyState === 'loading') { document.addEventListener('DOMContentLoaded', initGSAP); }
  else { setTimeout(initGSAP, 0); window.addEventListener('load', initGSAP); }
})();
</script>

{% schema %}
{
  "name": "Antonio's Menu Nav",
  "tag": "div",
  "class": "antonio-menu-nav-wrapper",
  "settings": [
    {
      "type": "header",
      "content": "Collection Handles",
      "info": "Match the Shopify collection handle for each real menu category."
    },
    { "type": "text", "id": "handle_pizzas",   "label": "Pizzas — collection handle",   "default": "pizzas"   },
    { "type": "text", "id": "handle_calzones", "label": "Calzones — collection handle", "default": "calzones" },
    { "type": "text", "id": "handle_desserts", "label": "Desserts — collection handle", "default": "desserts" },
    { "type": "text", "id": "handle_wings",    "label": "Wings — collection handle",    "default": "wings"    },
    { "type": "text", "id": "handle_pasta",    "label": "Pasta — collection handle",    "default": "pasta"    },
    { "type": "text", "id": "handle_salads",   "label": "Salads — collection handle",   "default": "salads"   },
    { "type": "text", "id": "handle_sides",    "label": "Sides — collection handle",    "default": "sides"    },
    { "type": "text", "id": "handle_bagels",   "label": "Bagels — collection handle",   "default": "bagels"   },
    { "type": "text", "id": "handle_heros",    "label": "Heros — collection handle",    "default": "heros"    }
  ],
  "presets": [{ "name": "Antonio's Menu Nav" }]
}
{% endschema %}
