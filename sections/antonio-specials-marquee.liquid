{%- comment -%}Antonio's Real NY Pizza — Daily Specials Ticker{%- endcomment -%}
{%- assign speed_duration = '25s' -%}
{%- if section.settings.speed == 'slow' -%}{%- assign speed_duration = '40s' -%}
{%- elsif section.settings.speed == 'fast' -%}{%- assign speed_duration = '15s' -%}
{%- endif -%}
{%- assign bg_color   = section.settings.bg_color   | default: '#1A1A1A' -%}
{%- assign text_color = section.settings.text_color | default: '#F5A623' -%}

<link rel="preconnect" href="https://fonts.googleapis.com" />
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
<link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&display=swap" rel="stylesheet" />

<style>
  #antonio-specials-{{ section.id }} {
    --asp-bg:        {{ bg_color }};
    --asp-text:      {{ text_color }};
    --asp-separator: #D0021B;
    --asp-height:    56px;
    --asp-font-size: 1.25rem;
    --asp-duration:  {{ speed_duration }};
  }
  #antonio-specials-{{ section.id }} .asp-ticker {
    display: flex; align-items: center; width: 100%;
    height: var(--asp-height); background: var(--asp-bg);
    overflow: hidden; position: relative; cursor: default;
  }
  #antonio-specials-{{ section.id }} .asp-track {
    display: flex; align-items: center;
    white-space: nowrap; will-change: transform;
  }
  #antonio-specials-{{ section.id }} .asp-item {
    display: inline-flex; align-items: center; gap: 0.45em;
    font-family: 'Bebas Neue', sans-serif; font-size: var(--asp-font-size);
    letter-spacing: 0.04em; color: var(--asp-text);
    text-transform: uppercase; line-height: 1;
    padding: 0 0.1em; user-select: none;
  }
  #antonio-specials-{{ section.id }} .asp-separator {
    display: inline-block; color: var(--asp-separator);
    font-size: 0.7em; margin: 0 1em; vertical-align: middle; flex-shrink: 0;
  }
  @media (max-width: 749px) {
    #antonio-specials-{{ section.id }} { --asp-font-size: 1rem; }
  }
  @media (prefers-reduced-motion: reduce) {
    #antonio-specials-{{ section.id }} .asp-track { animation: none !important; }
  }
</style>

<div id="antonio-specials-{{ section.id }}" data-section-id="{{ section.id }}">
  <div class="asp-ticker" id="asp-ticker-{{ section.id }}">
    <div class="asp-track" id="asp-track-{{ section.id }}">
      {%- for block in section.blocks -%}
        {%- assign emoji     = block.settings.emoji     | default: '' -%}
        {%- assign deal_text = block.settings.deal_text | default: '' -%}
        {%- assign price     = block.settings.price     | default: '' -%}
        <span class="asp-item" {{ block.shopify_attributes }}>
          {%- if emoji != '' -%}<span class="asp-emoji" aria-hidden="true">{{ emoji }}</span>{%- endif -%}
          <span class="asp-deal">{{ deal_text }}</span>
          {%- if price != '' -%}<span class="asp-price">&mdash; {{ price }}</span>{%- endif -%}
        </span>
        <span class="asp-separator" aria-hidden="true">&#9670;</span>
      {%- endfor -%}
    </div>
  </div>
</div>

<script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.5/gsap.min.js" defer></script>
<script>
(function () {
  'use strict';
  var SECTION_ID = '{{ section.id }}';
  var DURATION   = {{ speed_duration | remove: 's' }};
  function initTicker() {
    var ticker = document.getElementById('asp-ticker-' + SECTION_ID);
    var track  = document.getElementById('asp-track-'  + SECTION_ID);
    if (!ticker || !track || !window.gsap) return;
    var originalContent = track.innerHTML;
    var copies = 1;
    track.insertAdjacentHTML('beforeend', originalContent);
    function ensureWidth() {
      while (track.scrollWidth < window.innerWidth * 2) {
        track.insertAdjacentHTML('beforeend', originalContent);
        copies++;
        if (copies > 20) break;
      }
    }
    var tween;
    function startAnimation() {
      var setWidth = track.scrollWidth / (copies + 1);
      tween = gsap.to(track, {
        x: -setWidth, duration: DURATION, ease: 'none', repeat: -1,
        modifiers: { x: function(x) { return (parseFloat(x) % setWidth) + 'px'; } }
      });
      ticker.addEventListener('mouseenter', function() { tween && tween.pause(); });
      ticker.addEventListener('mouseleave', function() { tween && tween.resume(); });
      ticker.addEventListener('touchstart', function() { tween && tween.pause(); }, { passive: true });
      ticker.addEventListener('touchend',   function() { tween && tween.resume(); }, { passive: true });
    }
    if (document.readyState === 'complete') { ensureWidth(); startAnimation(); }
    else { window.addEventListener('load', function() { ensureWidth(); startAnimation(); }); }
  }
  function waitForGsap(n) {
    if (window.gsap) { initTicker(); }
    else if (n < 50) { setTimeout(function() { waitForGsap(n + 1); }, 100); }
  }
  waitForGsap(0);
})();
</script>

{% schema %}
{
  "name": "Specials Ticker",
  "tag": "section",
  "class": "antonio-specials-marquee",
  "max_blocks": 20,
  "blocks": [
    {
      "type": "deal",
      "name": "Deal",
      "settings": [
        { "type": "text", "id": "emoji",     "label": "Emoji",     "default": "🍕" },
        { "type": "text", "id": "deal_text", "label": "Deal Text", "default": "NY 18 INCH PIZZA" },
        { "type": "text", "id": "price",     "label": "Price",     "default": "$24.99" }
      ]
    }
  ],
  "settings": [
    {
      "type": "select", "id": "speed", "label": "Ticker Speed",
      "options": [
        { "value": "slow",   "label": "Slow (40s)"   },
        { "value": "medium", "label": "Medium (25s)" },
        { "value": "fast",   "label": "Fast (15s)"   }
      ],
      "default": "medium"
    },
    { "type": "color", "id": "bg_color",   "label": "Background Color", "default": "#1A1A1A" },
    { "type": "color", "id": "text_color", "label": "Text Color",       "default": "#F5A623" }
  ],
  "presets": [
    {
      "name": "Specials Ticker",
      "category": "Promotional",
      "blocks": [
        { "type": "deal", "settings": { "emoji": "🍕", "deal_text": "NY 18\" PIZZA",                        "price": "$24.99"   } },
        { "type": "deal", "settings": { "emoji": "🔥", "deal_text": "WINGS 6-10 PER LB",                   "price": "FROM $8.00" } },
        { "type": "deal", "settings": { "emoji": "🏆", "deal_text": "VOTED #1 PIZZA IN COLORADO",          "price": ""         } },
        { "type": "deal", "settings": { "emoji": "🍕", "deal_text": "MEGA DON 26\"",                        "price": "$48.99"   } },
        { "type": "deal", "settings": { "emoji": "🏅", "deal_text": "2ND BEST CHEESE SLICE IN THE WORLD",  "price": ""         } },
        { "type": "deal", "settings": { "emoji": "🧄", "deal_text": "GARLIC KNOTS DOZEN",                  "price": "$7.50"    } },
        { "type": "deal", "settings": { "emoji": "🍝", "deal_text": "PASTA MARINARA",                      "price": "FROM $6.00" } },
        { "type": "deal", "settings": { "emoji": "🇮🇹", "deal_text": "BACIO MOZZ · STANISLAUS TOMATOES · LONG-FERMENTED DOUGH", "price": "" } }
      ]
    }
  ]
}
{% endschema %}
