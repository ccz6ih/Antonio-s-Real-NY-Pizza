{% comment %}
  Antonio's Real NY Pizza — Customer Reviews Ticker
  Section: antonio-reviews.liquid
  Two-row infinite GSAP scroll on desktop, single row on mobile.
{% endcomment %}

<section
  class="antonio-reviews"
  id="antonio-reviews-{{ section.id }}"
  data-section-id="{{ section.id }}"
>
  <div class="antonio-reviews__inner">
    <h2 class="antonio-reviews__heading">What Colorado Is Saying</h2>

    {% if section.blocks.size > 0 %}
      {%- assign half = section.blocks.size | divided_by: 2 -%}

      <div class="antonio-reviews__track-wrapper" data-row="1">
        <div class="antonio-reviews__track" id="ar-track-1-{{ section.id }}">
          {% for block in section.blocks %}
            {%- assign stars_count = block.settings.stars | default: 5 -%}
            {%- assign review_text = block.settings.review | truncate: 123 -%}
            <div class="ar-card" {{ block.shopify_attributes }}>
              <div class="ar-card__stars" aria-label="{{ stars_count }} out of 5 stars">
                {%- for i in (1..5) -%}
                  {%- if i <= stars_count -%}<span class="ar-star ar-star--filled">&#9733;</span>
                  {%- else -%}<span class="ar-star ar-star--empty">&#9733;</span>
                  {%- endif -%}
                {%- endfor -%}
              </div>
              <p class="ar-card__quote">&ldquo;{{ review_text }}&rdquo;</p>
              <div class="ar-card__meta">
                <span class="ar-card__name">{{ block.settings.name | escape }}</span>
                {%- if block.settings.location != blank -%}<span class="ar-card__location">{{ block.settings.location | escape }}</span>{%- endif -%}
                {%- if block.settings.date != blank -%}<span class="ar-card__date">{{ block.settings.date | escape }}</span>{%- endif -%}
              </div>
            </div>
          {% endfor %}
          {% for block in section.blocks %}
            {%- assign stars_count = block.settings.stars | default: 5 -%}
            {%- assign review_text = block.settings.review | truncate: 123 -%}
            <div class="ar-card ar-card--clone" aria-hidden="true">
              <div class="ar-card__stars">
                {%- for i in (1..5) -%}
                  {%- if i <= stars_count -%}<span class="ar-star ar-star--filled">&#9733;</span>
                  {%- else -%}<span class="ar-star ar-star--empty">&#9733;</span>
                  {%- endif -%}
                {%- endfor -%}
              </div>
              <p class="ar-card__quote">&ldquo;{{ review_text }}&rdquo;</p>
              <div class="ar-card__meta">
                <span class="ar-card__name">{{ block.settings.name | escape }}</span>
                {%- if block.settings.location != blank -%}<span class="ar-card__location">{{ block.settings.location | escape }}</span>{%- endif -%}
                {%- if block.settings.date != blank -%}<span class="ar-card__date">{{ block.settings.date | escape }}</span>{%- endif -%}
              </div>
            </div>
          {% endfor %}
        </div>
      </div>

      <div class="antonio-reviews__track-wrapper antonio-reviews__track-wrapper--row2" data-row="2">
        <div class="antonio-reviews__track" id="ar-track-2-{{ section.id }}">
          {% for block in section.blocks %}
            {%- assign stars_count = block.settings.stars | default: 5 -%}
            {%- assign review_text = block.settings.review | truncate: 123 -%}
            <div class="ar-card">
              <div class="ar-card__stars" aria-label="{{ stars_count }} out of 5 stars">
                {%- for i in (1..5) -%}
                  {%- if i <= stars_count -%}<span class="ar-star ar-star--filled">&#9733;</span>
                  {%- else -%}<span class="ar-star ar-star--empty">&#9733;</span>
                  {%- endif -%}
                {%- endfor -%}
              </div>
              <p class="ar-card__quote">&ldquo;{{ review_text }}&rdquo;</p>
              <div class="ar-card__meta">
                <span class="ar-card__name">{{ block.settings.name | escape }}</span>
                {%- if block.settings.location != blank -%}<span class="ar-card__location">{{ block.settings.location | escape }}</span>{%- endif -%}
                {%- if block.settings.date != blank -%}<span class="ar-card__date">{{ block.settings.date | escape }}</span>{%- endif -%}
              </div>
            </div>
          {% endfor %}
          {% for block in section.blocks %}
            {%- assign stars_count = block.settings.stars | default: 5 -%}
            {%- assign review_text = block.settings.review | truncate: 123 -%}
            <div class="ar-card ar-card--clone" aria-hidden="true">
              <div class="ar-card__stars">
                {%- for i in (1..5) -%}
                  {%- if i <= stars_count -%}<span class="ar-star ar-star--filled">&#9733;</span>
                  {%- else -%}<span class="ar-star ar-star--empty">&#9733;</span>
                  {%- endif -%}
                {%- endfor -%}
              </div>
              <p class="ar-card__quote">&ldquo;{{ review_text }}&rdquo;</p>
              <div class="ar-card__meta">
                <span class="ar-card__name">{{ block.settings.name | escape }}</span>
                {%- if block.settings.location != blank -%}<span class="ar-card__location">{{ block.settings.location | escape }}</span>{%- endif -%}
                {%- if block.settings.date != blank -%}<span class="ar-card__date">{{ block.settings.date | escape }}</span>{%- endif -%}
              </div>
            </div>
          {% endfor %}
        </div>
      </div>

    {% else %}
      <p class="antonio-reviews__empty">Add review blocks in the theme editor to display testimonials.</p>
    {% endif %}
  </div>
</section>

<style>
  #antonio-reviews-{{ section.id }} {
    background-color: #1A1A1A;
    padding: 60px 0;
    overflow: hidden;
    width: 100%;
  }
  #antonio-reviews-{{ section.id }} .antonio-reviews__inner { max-width: 100%; }
  #antonio-reviews-{{ section.id }} .antonio-reviews__heading {
    font-family: 'Playfair Display', Georgia, serif;
    font-size: clamp(26px, 4vw, 40px);
    font-weight: 700;
    color: #FFFFFF;
    text-align: center;
    margin: 0 0 48px;
    padding-bottom: 14px;
    position: relative;
    display: inline-block;
    left: 50%;
    transform: translateX(-50%);
    white-space: nowrap;
  }
  #antonio-reviews-{{ section.id }} .antonio-reviews__heading::after {
    content: '';
    display: block;
    width: 100%;
    height: 3px;
    background-color: #C8291E;
    position: absolute;
    bottom: 0;
    left: 0;
    border-radius: 2px;
  }
  #antonio-reviews-{{ section.id }} .antonio-reviews__track-wrapper {
    overflow: hidden;
    width: 100%;
    margin-bottom: 20px;
    -webkit-mask-image: linear-gradient(to right, transparent 0%, #000 80px, #000 calc(100% - 80px), transparent 100%);
    mask-image: linear-gradient(to right, transparent 0%, #000 80px, #000 calc(100% - 80px), transparent 100%);
  }
  #antonio-reviews-{{ section.id }} .antonio-reviews__track-wrapper:last-child { margin-bottom: 0; }
  #antonio-reviews-{{ section.id }} .antonio-reviews__track-wrapper--row2 { display: none; }
  #antonio-reviews-{{ section.id }} .antonio-reviews__track {
    display: flex;
    flex-wrap: nowrap;
    gap: 20px;
    width: max-content;
    will-change: transform;
  }
  #antonio-reviews-{{ section.id }} .ar-card {
    flex: 0 0 280px;
    width: 280px;
    background-color: #FFFFFF;
    border-radius: 12px;
    padding: 20px;
    border-left: 3px solid #C8291E;
    box-shadow: 0 4px 20px rgba(0,0,0,0.3);
    display: flex;
    flex-direction: column;
    gap: 10px;
    box-sizing: border-box;
  }
  #antonio-reviews-{{ section.id }} .ar-card__stars { display: flex; gap: 2px; line-height: 1; }
  #antonio-reviews-{{ section.id }} .ar-star { font-size: 18px; line-height: 1; }
  #antonio-reviews-{{ section.id }} .ar-star--filled { color: #F5A623; }
  #antonio-reviews-{{ section.id }} .ar-star--empty  { color: #D4C5C5; }
  #antonio-reviews-{{ section.id }} .ar-card__quote {
    font-family: 'Playfair Display', Georgia, serif;
    font-style: italic;
    font-size: 15px;
    line-height: 1.55;
    color: #2C2C2C;
    margin: 0;
    flex: 1;
  }
  #antonio-reviews-{{ section.id }} .ar-card__meta { display: flex; flex-direction: column; gap: 2px; }
  #antonio-reviews-{{ section.id }} .ar-card__name     { font-family: 'Playfair Display', Georgia, serif; font-weight: 700; font-size: 13px; color: #1A1A1A; }
  #antonio-reviews-{{ section.id }} .ar-card__location { font-size: 12px; color: #888888; }
  #antonio-reviews-{{ section.id }} .ar-card__date     { font-size: 11px; color: #AAAAAA; }
  #antonio-reviews-{{ section.id }} .antonio-reviews__empty { color: #888888; text-align: center; font-size: 15px; padding: 0 20px; }
  @media screen and (min-width: 768px) {
    #antonio-reviews-{{ section.id }} .antonio-reviews__track-wrapper--row2 { display: block; }
  }
</style>

<script>
(function () {
  'use strict';
  var SECTION_ID = '{{ section.id }}';
  var GSAP_CDN   = 'https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.5/gsap.min.js';
  var CARD_W = 280, CARD_GAP = 20, CARD_STEP = 300;
  var BASE_SPD = 3.2, ROW2_MULT = 0.70;
  function initReviews() {
    if (typeof gsap === 'undefined') return;
    var section = document.getElementById('antonio-reviews-' + SECTION_ID);
    if (!section) return;
    section.querySelectorAll('.antonio-reviews__track-wrapper').forEach(function (wrapper, idx) {
      var track = wrapper.querySelector('.antonio-reviews__track');
      if (!track) return;
      var cardCount = track.querySelectorAll('.ar-card:not(.ar-card--clone)').length;
      if (!cardCount) return;
      var setWidth  = cardCount * CARD_STEP;
      var speedMult = idx === 1 ? ROW2_MULT : 1;
      var duration  = (cardCount * BASE_SPD) / speedMult;
      var tween = gsap.to(track, {
        x: '-=' + setWidth, duration: duration, ease: 'none', repeat: -1,
        modifiers: { x: gsap.utils.unitize(function (x) { return parseFloat(x) % setWidth; }) }
      });
      wrapper.addEventListener('mouseenter', function () { tween.pause(); });
      wrapper.addEventListener('mouseleave', function () { tween.resume(); });
    });
  }
  function loadGSAP(cb) {
    if (typeof gsap !== 'undefined') { cb(); return; }
    var s = document.createElement('script');
    s.src = GSAP_CDN; s.async = true; s.onload = cb;
    document.head.appendChild(s);
  }
  function ready(fn) {
    if (document.readyState !== 'loading') { fn(); }
    else { document.addEventListener('DOMContentLoaded', fn); }
  }
  ready(function () { loadGSAP(initReviews); });
  if (window.Shopify && window.Shopify.designMode) {
    document.addEventListener('shopify:section:load', function (e) {
      if (e.detail && e.detail.sectionId === SECTION_ID) { loadGSAP(initReviews); }
    });
  }
})();
</script>

{% schema %}
{
  "name": "Antonio's Reviews",
  "tag": "section",
  "class": "antonio-reviews-section",
  "max_blocks": 20,
  "settings": [],
  "blocks": [
    {
      "type": "review",
      "name": "Customer Review",
      "settings": [
        { "type": "range",    "id": "stars",    "label": "Star Rating", "min": 1, "max": 5, "step": 1, "default": 5 },
        { "type": "textarea", "id": "review",   "label": "Review Text", "default": "Best pizza in Colorado, period." },
        { "type": "text",     "id": "name",     "label": "Customer Name", "default": "John D." },
        { "type": "text",     "id": "location", "label": "Location", "default": "Estes Park, CO" },
        { "type": "text",     "id": "date",     "label": "Date", "default": "March 2025" }
      ]
    }
  ],
  "presets": [
    {
      "name": "Antonio's Reviews",
      "blocks": [
        {
          "type": "review",
          "settings": {
            "stars": 5,
            "review": "I've lived in Colorado my whole life and never believed I'd find pizza this good without boarding a plane to New York. Antonio's is the real deal — voted #1 in Colorado and every bite proves it. I can't believe it's right here in Estes Park.",
            "name": "Sarah M.",
            "location": "Estes Park, CO",
            "date": "February 2025"
          }
        },
        {
          "type": "review",
          "settings": {
            "stars": 5,
            "review": "I've tried every pizza place along the Front Range looking for that authentic NY taste and they all fall flat. Antonio's nails it completely. The crust, the sauce, the cheese pull — nothing else in Colorado even comes close. This is the only place I go now.",
            "name": "Mike T.",
            "location": "Longmont, CO",
            "date": "January 2025"
          }
        },
        {
          "type": "review",
          "settings": {
            "stars": 5,
            "review": "Made the drive down from Fort Collins specifically for the wings and pizza after a friend wouldn't stop talking about this place. Absolutely worth every mile. The wings are crispy perfection and the pizza is on another level. Already planning my next trip.",
            "name": "Jennifer K.",
            "location": "Fort Collins, CO",
            "date": "March 2025"
          }
        },
        {
          "type": "review",
          "settings": {
            "stars": 5,
            "review": "The Grandma Lita is unlike anything I've ever eaten. The combination of flavors is bold and inventive but somehow perfectly balanced — it shouldn't work and yet it's the best slice I've had anywhere. Antonio is a genuine artist. Boulder is lucky to be close to this.",
            "name": "David R.",
            "location": "Boulder, CO",
            "date": "February 2025"
          }
        },
        {
          "type": "review",
          "settings": {
            "stars": 5,
            "review": "We made the trip up from Denver just to try the Mega Don and the Godfather and they both exceeded every expectation. The Godfather alone is worth the drive — loaded with real Italian ingredients, perfectly balanced, incredible crust. We're already planning our next visit.",
            "name": "Lisa & Tom P.",
            "location": "Denver, CO",
            "date": "March 2025"
          }
        },
        {
          "type": "review",
          "settings": {
            "stars": 5,
            "review": "The Spicy Calabrian changed my life. I know that sounds dramatic but I genuinely think about it all the time. The heat builds perfectly, the toppings are generous and fresh, and that crust is everything. Antonio competed in Italy and you can taste every bit of that skill.",
            "name": "Chris A.",
            "location": "Loveland, CO",
            "date": "January 2025"
          }
        }
      ]
    }
  ]
}
{% endschema %}
