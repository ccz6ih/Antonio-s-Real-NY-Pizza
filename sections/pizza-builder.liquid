{{ 'pizza-builder.css' | asset_url | stylesheet_tag }}

{%- assign option_value = product.metafields.custom.pizza_option_set.value | downcase | strip -%}

<div class="pizza-builder-section" data-product-id="{{ product.id }}">
  {%- case option_value -%}
    {%- when 'whole-pizza' -%}
      {%- render 'pizza-builder-whole', product: product -%}
    {%- when 'calzone' -%}
      {%- render 'pizza-builder-calzone', product: product -%}
    {%- when 'appetizer' -%}
      {%- render 'pizza-builder-appetizer', product: product -%}
    {%- when 'pasta' -%}
      {%- render 'pizza-builder-simple', product: product -%}
    {%- when 'salad' -%}
      {%- render 'pizza-builder-simple', product: product -%}
    {%- when 'sandwich' -%}
      {%- render 'pizza-builder-simple', product: product -%}
    {%- when 'dessert' -%}
      {%- render 'pizza-builder-simple', product: product -%}
    {%- when 'drink' -%}
      {%- render 'pizza-builder-simple', product: product -%}
    {%- else -%}
      {%- render 'pizza-builder-simple', product: product -%}
  {%- endcase -%}
</div>

{% schema %}
{
  "name": "Pizza Builder",
  "tag": "section",
  "settings": [],
  "presets": [
    {
      "name": "Pizza Builder"
    }
  ]
}
{% endschema %}
